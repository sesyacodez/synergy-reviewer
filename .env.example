# OpenRouter (single key; use `:free` model IDs for no-cost demos — see https://openrouter.ai/models?q=free)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: your app URL (recommended by OpenRouter for free-tier attribution)
# OPENROUTER_HTTP_REFERER=https://your-deployment.example.com

# Optional: comma-separated reviewer models (defaults to three different free models)
# OPENROUTER_REVIEW_MODELS=meta-llama/llama-3.2-3b-instruct:free,mistralai/mistral-7b-instruct:free,google/gemma-2-9b-it:free

# Optional: synthesizer model (defaults to a larger free Llama instruct model)
# OPENROUTER_SYNTH_MODEL=meta-llama/llama-3.3-70b-instruct:free

# GitHub App Configuration
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# Optional
AGENT_COUNT=3
